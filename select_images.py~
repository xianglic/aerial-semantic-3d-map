#!/usr/bin/env python3
import os
import shutil
from pathlib import Path

def select_images_every_100():
    source_dir = Path("/home/ubuntu/VGGT/anafi_usa_20250812")
    target_dir = Path("/home/ubuntu/VGGT/anafi_usa_selected")
    
    # 创建目标文件夹
    target_dir.mkdir(exist_ok=True)
    
    # 获取所有jpg文件并按序号排序
    jpg_files = sorted([f for f in source_dir.glob("*.jpg")])
    
    # 每100张选择一张
    selected_count = 0
    for i in range(0, len(jpg_files), 100):
        source_file = jpg_files[i]
        target_file = target_dir / source_file.name
        
        # 复制文件
        shutil.copy2(source_file, target_file)
        selected_count += 1
        print(f"已选择: {source_file.name}")
    
    print(f"\n总共选择了 {selected_count} 张图片")
    print(f"从 {len(jpg_files)} 张图片中每100张选择一张")
    print(f"选中的图片已保存到: {target_dir}")

if __name__ == "__main__":
    select_images_every_100()